{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Bundle Install",
      "type": "shell",
      "command": "bundle install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Test",
      "type": "shell",
      "command": "bundle exec rake test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    },
    {
      "label": "Lint",
      "type": "shell",
      "command": "bundle exec rubocop",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Build Docs Site",
      "type": "shell",
      "command": "bundle exec jekyll build --source site --destination /tmp/jekyll-awesome-nav-site --disable-disk-cache",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Serve Docs Site",
      "type": "shell",
      "command": "bundle exec jekyll serve --source site --destination /tmp/jekyll-awesome-nav-site --livereload",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "jekyll",
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 1,
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".*Generating.*",
          "endsPattern": ".*Server address:.*"
        }
      }
    }
  ]
}
